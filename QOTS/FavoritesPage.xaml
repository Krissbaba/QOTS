<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Class="QOTS.FavoritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

	<VerticalStackLayout Padding="20">

		<Label Text="⭐ Kedvencek" FontSize="24"/>

		<CollectionView x:Name="FavoritesList">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border Stroke="Gray" Padding="10">
						<VerticalStackLayout>
							<Label Text="{Binding Text}" FontAttributes="Bold"/>
							<Label Text="{Binding BookInfo}" FontSize="12"/>
						</VerticalStackLayout>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</VerticalStackLayout>

</ContentPage>