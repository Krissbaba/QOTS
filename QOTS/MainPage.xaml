<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="QOTS.MainPage">

	<Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10" Padding="20">

		<!-- Cím -->
		<Label Text="📚 Idézetgyűjtő"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Grid.Row="0"/>

		<!-- INPUT (SCROLLAL!) -->
		<ScrollView Grid.Row="1">
			<Border Stroke="#ddd" StrokeThickness="1" Padding="10">
				<VerticalStackLayout Spacing="10">

					<Entry x:Name="QuoteEntry" Placeholder="Idézet..." />
					<Entry x:Name="BookTitleEntry" Placeholder="Könyv címe" />
					<Entry x:Name="AuthorEntry" Placeholder="Szerző" />
					<Entry x:Name="TagsEntry" Placeholder="Tagek (pl: motiváció)" />
					<Entry x:Name="PageEntry" Placeholder="Oldalszám" Keyboard="Numeric" />

					<Button x:Name="SaveButton"
                            Text="Mentés"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="10"
                            Clicked="OnSaveClicked"/>

				</VerticalStackLayout>
			</Border>
		</ScrollView>

		<!-- KERESŐ -->
		<Entry x:Name="SearchEntry"
               Placeholder="🔍 Keresés..."
               BackgroundColor="#f5f5f5"
               Margin="0,10"
               Grid.Row="2"
               TextChanged="OnSearchTextChanged"/>

		<!-- LISTA -->
		<CollectionView x:Name="QuotesList"
                        Grid.Row="3">

			<CollectionView.ItemTemplate>
				<DataTemplate>
					<SwipeView Threshold="50">

						<!-- JOBBRA SWIPE = TÖRLÉS -->
						<SwipeView.RightItems>
							<SwipeItems Mode="Execute">
								<SwipeItem Text="Törlés"
                                           BackgroundColor="Red"
                                           Invoked="OnDeleteClicked"
                                           CommandParameter="{Binding .}" />
							</SwipeItems>
						</SwipeView.RightItems>

						<!-- KÁRTYA -->
						<Border Stroke="#eee" 
                                StrokeThickness="1" 
                                Padding="12" 
                                Margin="0,5"
                                BackgroundColor="White">

							<VerticalStackLayout Spacing="6">

								<Label Text="{Binding Text}" 
                                       FontAttributes="Bold"
                                       FontSize="16"/>

								<Label Text="{Binding BookInfo}" 
                                       FontSize="12"
                                       TextColor="Gray"/>

								<Label Text="{Binding Tags}" 
                                       FontSize="12"
                                       TextColor="#888"/>

								<Button Text="⭐"
                                        BackgroundColor="#FFD700"
                                        Clicked="OnFavoriteClicked"
                                        CommandParameter="{Binding .}" />

							</VerticalStackLayout>

						</Border>

					</SwipeView>
				</DataTemplate>
			</CollectionView.ItemTemplate>

		</CollectionView>

	</Grid>

</ContentPage>